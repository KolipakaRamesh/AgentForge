# =============================================================================
# AgentForge — .gitignore
# =============================================================================

# -------------------------
# AgentForge: Generated Output
# -------------------------
/ExportedProjects/
.pinecone/
vector_cache/
*.vdb
*.index

# -------------------------
# Environment Variables (NEVER commit these)
# -------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
*.env

# -------------------------
# Frontend — Node.js / Next.js
# -------------------------
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/.turbo/
frontend/coverage/
frontend/.eslintcache
frontend/next-env.d.ts

# -------------------------
# Frontend — Convex Generated Files
# (Auto-generated by `npx convex dev`, do not commit)
# -------------------------
frontend/convex/_generated/

# -------------------------
# Agent Engine — Python
# -------------------------
agent-engine/__pycache__/
agent-engine/**/__pycache__/
agent-engine/*.py[cod]
agent-engine/*.pyo
agent-engine/*.pyd
agent-engine/.Python
agent-engine/env/
agent-engine/venv/
agent-engine/.venv/
agent-engine/.env
agent-engine/pip-log.txt
agent-engine/pip-delete-this-directory.txt
agent-engine/.pytest_cache/
agent-engine/.ruff_cache/
agent-engine/.mypy_cache/
agent-engine/dist/
agent-engine/build/
agent-engine/*.egg-info/
agent-engine/.coverage
agent-engine/htmlcov/

# -------------------------
# Logs
# -------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -------------------------
# OS / System Files
# -------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -------------------------
# Editor / IDE
# -------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.project
.classpath
.settings/
*.iml

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo

# -------------------------
# Testing
# -------------------------
coverage/
.nyc_output/

# -------------------------
# Misc
# -------------------------
*.pem
.turbo/
